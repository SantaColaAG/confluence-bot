# Two modes: serve (Railway) or refresh (local mac)

MODE=serve

# --- serve mode (Railway) ---
TG_TOKEN=
ALLOWED_USER_IDS=123456789,987654321
REFRESH_SECRET=generate-a-long-random-string
# PORT is injected by Railway; CACHE_DIR=/data when running in Docker

# --- refresh mode (local mac) ---
# MODE=refresh
# CONFLUENCE_URL=https://confluence.example.com
# CONFLUENCE_PAT=
# ROOT_PAGE_ID=
# RAILWAY_URL=https://your-app.up.railway.app
# REFRESH_SECRET=same-as-on-railway
# HTTPS_PROXY=http://proxy.example:8080
